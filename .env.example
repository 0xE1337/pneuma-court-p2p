# ─── Anthropic (Claude API for jurors) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Arc Testnet (where PneumaCourt contract lives) ───────────
ARC_RPC_URL=https://rpc.arc-testnet.example
PNEUMA_COURT_ADDRESS=0x3371e96b29b5565EF2622A141cDAD3912Daa66AC

# Wallet that finalizes verdicts on-chain (must have JUROR_ROLE
# on PneumaCourt — see docs/pneuma-court-on-arc.md for grant tx)
COURT_FINALIZER_PRIVATE_KEY=0x...

# ─── anet (P2P service gateway) ───────────────────────────────
# Each daemon uses a separate HOME so multiple agents can co-exist
# on one laptop. scripts/four-node.sh sets these automatically.
ANET_HOME=/tmp/anet-p2p-court

# ─── Court agent service ──────────────────────────────────────
COURT_HOST=127.0.0.1
COURT_PORT=8088
COURT_COST_PER_CALL=20

# ─── Juror agents ─────────────────────────────────────────────
JUROR_COST_PER_CALL=5
