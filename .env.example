# ═══════════════════════════════════════════════════════════════
#  REQUIRED — Claude API for jurors
# ═══════════════════════════════════════════════════════════════

# Anthropic Claude API. Each juror agent calls Claude with a
# domain-specific system prompt to produce its verdict.
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ═══════════════════════════════════════════════════════════════
#  REQUIRED — Arc Testnet on-chain write (gas is FREE on testnet)
# ═══════════════════════════════════════════════════════════════
#
# Court writes every verdict on-chain by default. Gas is paid by
# this finalizer wallet (NOT by callers — anet users have no EVM
# wallet). Arc Testnet ETH is free from the faucet, so the court
# operator's actual gas cost is ~zero.
#
# If any one of these three vars is missing, the court automatically
# falls back to anet-only (advisory) mode — no setup hassle.
#
# Setup: see docs/onchain-bonus.md for the JUROR_ROLE grant command
# and the testnet faucet link.

ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app
PNEUMA_COURT_ADDRESS=0x3371e96b29b5565EF2622A141cDAD3912Daa66AC
COURT_FINALIZER_PRIVATE_KEY=0x...
#   └─ pays gas + must hold JUROR_ROLE on PneumaCourt
#   └─ on Arc Testnet, gas IS USDC (one address: 0x3600...0000).
#      Get free testnet USDC from https://faucet.circle.com

# ═══════════════════════════════════════════════════════════════
#  anet daemon
# ═══════════════════════════════════════════════════════════════
# Each daemon uses a separate HOME so multiple agents co-exist
# on one laptop. scripts/four-node.sh sets these automatically.
ANET_HOME=/tmp/anet-p2p-court

# ═══════════════════════════════════════════════════════════════
#  Court agent service
# ═══════════════════════════════════════════════════════════════
COURT_HOST=127.0.0.1
COURT_PORT=8088
COURT_COST_PER_CALL=20

# ═══════════════════════════════════════════════════════════════
#  Juror agents
# ═══════════════════════════════════════════════════════════════
JUROR_COST_PER_CALL=5
