# ═══════════════════════════════════════════════════════════════
#  REQUIRED — for default anet-only deliberation
# ═══════════════════════════════════════════════════════════════

# Anthropic Claude API (each juror agent calls Claude with a
# domain-specific system prompt to produce its verdict)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ═══════════════════════════════════════════════════════════════
#  OPTIONAL — only needed if you want to enable on-chain proofs
# ═══════════════════════════════════════════════════════════════
#
# Default behavior: court runs entirely inside anet, all settlement
# in 🐚 Shell credits. No EVM wallet needed.
#
# If you (the court operator) want to offer "on-chain proof of
# verdict" as a premium service to callers, set COURT_ENABLE_ONCHAIN=1
# and configure the three vars below. Gas is paid by you (the court
# operator), not by callers — anet callers do not need an EVM wallet.

COURT_ENABLE_ONCHAIN=0

# Only read when COURT_ENABLE_ONCHAIN=1:
# ARC_RPC_URL=https://rpc.arc-testnet.example
# PNEUMA_COURT_ADDRESS=0x3371e96b29b5565EF2622A141cDAD3912Daa66AC
# COURT_FINALIZER_PRIVATE_KEY=0x...
#   └─ this wallet pays gas + must have JUROR_ROLE on the contract
#      (see docs/onchain-bonus.md for grant + funding instructions)

# ═══════════════════════════════════════════════════════════════
#  anet daemon
# ═══════════════════════════════════════════════════════════════
# Each daemon uses a separate HOME so multiple agents co-exist
# on one laptop. scripts/four-node.sh sets these automatically.
ANET_HOME=/tmp/anet-p2p-court

# ═══════════════════════════════════════════════════════════════
#  Court agent service
# ═══════════════════════════════════════════════════════════════
COURT_HOST=127.0.0.1
COURT_PORT=8088
COURT_COST_PER_CALL=20

# ═══════════════════════════════════════════════════════════════
#  Juror agents
# ═══════════════════════════════════════════════════════════════
JUROR_COST_PER_CALL=5
